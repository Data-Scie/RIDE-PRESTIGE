{
  "expo": {
    "name": "Ride Prestige Affiliate & Driver",
    "slug": "ride-prestige-affiliate-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brand/ride-prestige-mark.png",
    "scheme": "rpaffiliate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#030303"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rideprestige.driver"
    },
    "android": {
      "package": "com.rideprestige.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/brand/ride-prestige-mark.png",
        "backgroundColor": "#030303",
        "monochromeImage": "./assets/images/brand/ride-prestige-mark.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/brand/ride-prestige-mark.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/brand/ride-prestige-mark.png",
          "imageWidth": 200,
          "backgroundColor": "#030303",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Ride Prestige uses your location while you're on an active ride so customers and dispatch can see your live position."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/brand/ride-prestige-mark.png",
          "color": "#D7B46A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "50bd3566-c29b-4119-8391-991fadc2e1f0"
      }
    },
    "owner": "sparc476"
  }
}
