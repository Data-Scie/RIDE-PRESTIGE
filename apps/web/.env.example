NEXT_PUBLIC_API_URL="https://your-render-api.onrender.com"
API_URL="https://your-render-api.onrender.com"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_STRIPE_KEY=""
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable analytics
# entirely - the cookie consent banner will only load it after a visitor accepts.
