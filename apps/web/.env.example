# Sentry error tracking DSN for the web app. Leave empty to disable - see HANDOVER.md.
NEXT_PUBLIC_SENTRY_DSN=""
# Optional - only needed to upload source maps to Sentry during build. Leave empty to skip.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
