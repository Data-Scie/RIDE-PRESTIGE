generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Admin Users ──────────────────────────────────────────────────────────────

model Admin {
  id           String   @id
  email        String   @unique
  passwordHash String
  name         String
  role         String   // super_admin | admin | ops
  createdAt    DateTime @default(now())
}

// ─── Customers ────────────────────────────────────────────────────────────────

model Customer {
  id             String   @id
  fullName       String
  email          String   @unique
  phone          String?
  passwordHash   String?
  authProvider   String   @default("password") // password | google
  isVerified     Boolean  @default(false)
  totalBookings  Int      @default(0)
  expoPushToken  String?
  createdAt      DateTime @default(now())
}

// ─── Affiliates ───────────────────────────────────────────────────────────────

model Affiliate {
  id                    String   @id
  companyName           String
  tradingName           String
  contactPerson         String
  email                 String   @unique
  phone                 String
  passwordHash          String
  address               String
  city                  String
  postcode              String
  operatorLicenceNumber String
  companyRegNumber      String
  vatNumber             String?
  serviceAreas          String[]
  bankAccountName       String
  sortCode              String
  accountNumber         String
  isApproved            Boolean  @default(false)
  rating                Float    @default(0)
  totalJobs             Int      @default(0)
  totalEarnings         Float    @default(0)
  expoPushToken         String?
  createdAt             DateTime @default(now())

  drivers       Driver[]
  fleetVehicles FleetVehicle[]
  documents     AffiliateDocument[]
  rideResponses AffiliateRideResponse[]

  @@index([isApproved])
  @@index([createdAt])
}

// ─── Drivers ─────────────────────────────────────────────────────────────────

model Driver {
  id                     String    @id
  fullName               String
  email                  String    @unique
  phone                  String
  passwordHash           String
  address                String
  city                   String
  postcode               String
  dateOfBirth            String
  drivingLicenceNumber   String
  privateHireBadgeNumber String
  nationalInsurance      String?
  driverType             String    // affiliateDriver | independentDriver
  affiliateId            String?
  affiliate              Affiliate? @relation(fields: [affiliateId], references: [id])
  status                 String    @default("offline") // available | busy | offline
  rating                 Float     @default(0)
  totalJobs              Int       @default(0)
  totalEarnings          Float     @default(0)
  documentsStatus        String    @default("missing") // approved | pending | rejected | expired | missing
  assignedVehicleId      String?
  isApproved             Boolean   @default(false)
  applicationStatus      String    @default("pending") // pending | approved | rejected | suspended
  joinedDate             DateTime  @default(now())
  latitude               Float?
  longitude              Float?
  lastLocationUpdate     DateTime?
  serviceAreas           String[]  @default([])
  expoPushToken          String?
  updatedAt              DateTime  @updatedAt

  documents DriverDocument[]
  vehicles  FleetVehicle[] @relation("IndependentDriverVehicles")
  rideOffers RideOffer[]

  @@index([affiliateId])
  @@index([driverType])
  @@index([status, isApproved])
  @@index([applicationStatus])
  @@index([joinedDate])
}

// ─── Driver Documents ─────────────────────────────────────────────────────────

model DriverDocument {
  id               String   @id
  driverId         String
  driver           Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  type             String
  label            String
  status           String   @default("missing") // approved | pending | rejected | expired | missing
  expiryDate       String?
  fileUrl          String?
  uploadedAt       DateTime?
  rejectionReason  String?

  @@index([driverId, status])
  @@index([status])
}

// Affiliate Documents
model AffiliateDocument {
  id               String    @id
  affiliateId      String
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  type             String
  label            String
  status           String    @default("missing") // approved | pending | rejected | expired | missing
  expiryDate       String?
  fileUrl          String?
  uploadedAt       DateTime?
  rejectionReason  String?

  @@unique([affiliateId, type])
  @@index([affiliateId, status])
}

// ─── Operational Fleet Vehicles ───────────────────────────────────────────────

model FleetVehicle {
  id                String    @id
  make              String
  model             String
  year              Int
  registration      String    @unique
  vehicleType       String    // Saloon | Estate | MPV | Executive | Minibus | Coach | Luxury
  vehicleCategory   String    // prestige | minibus | coaches | taxi
  colour            String
  passengerCapacity Int
  luggageCapacity   Int
  motExpiry         String
  insuranceExpiry   String
  phvLicenceExpiry  String
  status            String    @default("available") // available | in_use | maintenance | offline
  affiliateId       String?
  affiliate         Affiliate? @relation(fields: [affiliateId], references: [id])
  ownerDriverId     String?
  ownerDriver       Driver?     @relation("IndependentDriverVehicles", fields: [ownerDriverId], references: [id], onDelete: SetNull)
  assignedDriverId  String?
  approvalStatus    String      @default("pending") // pending | approved | rejected | suspended
  isApproved        Boolean     @default(false)
  rejectionReason   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @default(now()) @updatedAt

  documents         VehicleDocument[]

  @@index([affiliateId])
  @@index([ownerDriverId])
  @@index([vehicleCategory, isApproved, approvalStatus, status])
  @@index([approvalStatus])
  @@index([status])
}

model VehicleDocument {
  id               String       @id
  vehicleId        String
  vehicle          FleetVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type             String
  label            String
  status           String       @default("missing") // approved | pending | rejected | expired | missing
  expiryDate       String?
  fileUrl          String?
  uploadedAt       DateTime?
  rejectionReason  String?

  @@unique([vehicleId, type])
  @@index([vehicleId, status])
  @@index([status])
}

// ─── Website Fleet (CMS) ─────────────────────────────────────────────────────

model WebsiteVehicle {
  id           String   @id
  categorySlug String   // prestige | minibus | coaches | taxi
  name         String
  description  String
  passengers   Int
  luggage      String?
  features     String[]
  imageUrl     String
  available    Boolean  @default(true)
  priceNote    String?
  badge        String?

  @@index([categorySlug, available])
  @@index([available])
}

model WebsiteFleetCategory {
  id          String  @id
  slug        String  @unique
  name        String
  tagline     String
  description String
  icon        String
  available   Boolean @default(true)
  order       Int

  @@index([available, order])
}

// ─── Jobs (operational rides) ─────────────────────────────────────────────────

model Job {
  id                    String    @id
  bookingRef            String
  bookingId             String?
  customerId            String?
  customerName          String
  customerPhone         String
  customerEmail         String?
  pickupAddress         String
  pickupLatitude        Float?
  pickupLongitude       Float?
  dropoffAddress        String
  stops                 Json      @default("[]")
  dateTime              DateTime
  passengerCount        Int       @default(1)
  luggageCount          Int       @default(0)
  vehicleTypeRequested  String
  vehicleCategory       String
  fareAmount            Float
  commissionAmount      Float
  affiliatePayoutAmount Float
  driverPayoutAmount    Float
  distance              String
  estimatedDuration     String
  specialInstructions   String?
  flightNumber          String?
  trainNumber           String?
  status                String    // JobStatus values
  affiliateId           String?
  assignedDriverId      String?
  assignedVehicleId     String?
  completedAt           DateTime?
  customerRating        Float?
  customerFeedback      String?
  driverRating          Float?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  rideOffers         RideOffer[]
  affiliateResponses AffiliateRideResponse[]

  @@index([status, dateTime])
  @@index([status, completedAt])
  @@index([affiliateId, status])
  @@index([assignedDriverId, status])
  @@index([assignedVehicleId])
  @@index([bookingId])
  @@index([vehicleCategory, status])
  @@index([createdAt])
}

model RideOffer {
  id         String   @id @default(uuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  driverId   String
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicleId  String
  status     String   @default("pending") // pending | accepted | declined | expired | withdrawn
  expiresAt  DateTime
  respondedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([jobId, driverId])
  @@index([driverId, status, expiresAt])
  @@index([jobId, status])
}

model AffiliateRideResponse {
  id          String    @id @default(uuid())
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  status      String    @default("declined") // declined
  respondedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([jobId, affiliateId])
  @@index([affiliateId, status])
  @@index([jobId, status])
}

// ─── Bookings (website-originated) ──────────────────────────────────────────

model Booking {
  id              String   @id
  reference       String   @unique
  status          String   @default("pending")
  customerId      String?
  customerData    Json     // { fullName, phone, email }
  journeyData     Json     // { pickupPostcode, dropoffPostcode, bookingType, date?, time?, passengers, notes? }
  vehicleCategory String
  vehicleId       String?
  estimatedMiles  Float?
  estimatedFare   Float?
  couponCode      String?
  discountAmount  Float?
  adminNotes      String?
  jobId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([customerId, createdAt])
  @@index([jobId])
  @@index([vehicleCategory])
}

// ─── Earnings ─────────────────────────────────────────────────────────────────

model EarningEntry {
  id                 String    @id
  jobId              String
  bookingRef         String
  entityId           String    // polymorphic — affiliateId or driverId
  entityType         String    // affiliate | driver
  date               DateTime
  grossAmount        Float
  commissionDeducted Float     @default(0)
  netAmount          Float
  status             String    @default("pending") // paid | pending | processing
  paymentMethod      String?
  payoutReference    String?
  paidAt             DateTime?
  createdAt          DateTime  @default(now())

  @@index([entityId, entityType, date])
  @@index([jobId])
  @@index([status, date])
}

// ─── Payments (customer-side) ──────────────────────────────────────────────────

model Payment {
  id             String    @id
  bookingId      String?
  jobId          String?
  bookingRef     String?
  customerId     String?
  customerName   String
  amount         Float
  method         String    // card | cash | bank_transfer
  status         String    @default("pending") // pending | paid | failed | refunded
  transactionRef String?
  paidAt         DateTime?
  refundedAt     DateTime?
  refundAmount   Float?
  refundReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([bookingId])
  @@index([jobId])
  @@index([status, createdAt])
  @@index([transactionRef])
}

// ─── Invoices ───────────────────────────────────────────────────────────────────

model Invoice {
  id          String    @id
  type        String    // customer_receipt | affiliate_payout | driver_payout
  entityId    String
  entityName  String
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Float
  status      String    @default("draft") // draft | issued | paid
  issuedAt    DateTime?
  createdAt   DateTime  @default(now())
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id            String   @id @default(uuid())
  recipientId   String   // polymorphic — any userId
  recipientRole String   // admin | ops | affiliate | driver | customer
  title         String
  body          String
  type          String   // job | system | earnings | document | booking
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([recipientId, recipientRole, isRead, createdAt])
}

// ─── Support Tickets ─────────────────────────────────────────────────────────

model SupportTicket {
  id               String   @id
  reference        String   @unique
  type             String   // enquiry | complaint | booking_support | other
  status           String   @default("open") // open | in_progress | resolved
  customerData     Json     // { name, email, phone? }
  bookingReference String?
  subject          String
  message          String
  adminNotes       String?
  reply            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, createdAt])
  @@index([bookingReference])
}

// ─── Pricing Config ───────────────────────────────────────────────────────────

model PricingConfig {
  id                      String @id @default("default")
  prestigeRatePerMile     Float
  prestigeHourlyRate      Float
  minibusRatePerMile      Float
  minibusRate16Seater     Float
  minibusRate24Seater     Float
  minibusRate32Seater     Float
  coachesRatePerMile      Float
  coachesHourlyRate       Float
  taxiRatePerMile         Float
  taxiMinimumFare         Float
  driverSearchRadiusMiles Float
  commissionPercentage    Float
  driverPayoutPercentage  Float
}

// ─── Site Settings ────────────────────────────────────────────────────────────

model SiteSettings {
  id                 String  @id @default("default")
  siteName           String
  tagline            String
  heroSubtitle       String
  logoUrl            String
  faviconUrl         String
  brandColor         String
  accentColor        String
  contactEmail       String
  phoneNumber        String
  address            String
  socialLinks        Json    // { twitter?, instagram?, linkedin?, facebook? }
  seoDefaults        Json    // { title, description, ogImage }
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
}

// ─── Navigation ───────────────────────────────────────────────────────────────

model NavigationItem {
  id      String  @id
  label   String
  href    String
  visible Boolean @default(true)
  order   Int

  @@index([visible, order])
}

// ─── Promotions ───────────────────────────────────────────────────────────────

model Promotion {
  id            String  @id
  title         String
  description   String
  couponCode    String?
  discountType  String  // percentage | fixed
  discountValue Float
  startDate     String
  endDate       String
  active        Boolean @default(true)
  imageUrl      String?
  terms         String
  category      String? // prestige | minibus | coaches | taxi | all

  @@index([active, startDate, endDate])
}

// ─── FAQ Items ────────────────────────────────────────────────────────────────

model FAQItem {
  id       String  @id
  question String
  answer   String
  category String
  order    Int
  active   Boolean @default(true)

  @@index([active, category, order])
}

// ─── Cancellation Policy ──────────────────────────────────────────────────────

model CancellationPolicy {
  id                 String @id @default("default")
  minHoursBeforeRide Int    @default(8)
  refundWindowHours  Int    @default(48)
  message            String @default("Cancellations made more than 8 hours before your scheduled pickup are eligible for a full refund. Cancellations made within 8 hours of the pickup time are non-refundable. Refunds are processed within 48 hours of approval.")
}

// ─── Website Pages (CMS) ──────────────────────────────────────────────────────

model WebsitePage {
  id              String @id
  slug            String @unique
  title           String
  seoTitle        String
  metaDescription String
  ogTitle         String
  ogDescription   String
  sectionsJson    Json   // PageSection[]
}

// ─── Vacancies ────────────────────────────────────────────────────────────────

model Vacancy {
  id           String   @id @default(uuid())
  title        String
  department   String
  location     String
  type         String   @default("full-time") // full-time | part-time | contract
  description  String
  requirements String
  salary       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([active, createdAt])
}

// ─── Courses ─────────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  duration    String
  price       Float?
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([active, createdAt])
}

// ─── Attributes ───────────────────────────────────────────────────────────────

model Attribute {
  id       String   @id @default(uuid())
  key      String   @unique
  label    String
  type     String   @default("text") // text | number | boolean | select
  options  String[]
  category String   @default("vehicle") // vehicle | booking | driver
  active   Boolean  @default(true)

  @@index([category, active])
}

// ─── Ride Status History ──────────────────────────────────────────────────────

model RideStatusHistory {
  id            String   @id @default(uuid())
  jobId         String
  fromStatus    String?
  toStatus      String
  changedBy     String?
  changedByRole String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([jobId, createdAt])
}
model RideFlowEvent {
  id             String   @id @default(uuid())
  jobId          String
  bookingId      String?
  bookingRef     String
  eventType      String
  title          String
  description    String?
  fromStatus     String?
  toStatus       String?
  actorId        String?
  actorRole      String?
  actorName      String?
  affiliateId    String?
  driverId       String?
  vehicleId      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([jobId, createdAt])
  @@index([bookingId, createdAt])
  @@index([bookingRef, createdAt])
  @@index([eventType])
}

// ─── Driver Location History ──────────────────────────────────────────────────

model DriverLocationHistory {
  id         String   @id @default(uuid())
  driverId   String
  jobId      String?
  latitude   Float
  longitude  Float
  speed      Float?
  heading    Float?
  accuracy   Float?
  recordedAt DateTime @default(now())

  @@index([driverId, recordedAt])
  @@index([jobId, recordedAt])
}
