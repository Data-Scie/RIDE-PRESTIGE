{
  "name": "@ride-prestige/api",
  "version": "1.0.0",
  "description": "Ride Prestige — Full Corporate Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test:ride-lifecycle": "node scripts/test-ride-lifecycle.js",
    "test:driver-applications": "node scripts/test-driver-applications.js",
    "test:independent-dispatch": "node scripts/test-independent-dispatch.js",
    "test:affiliate-dispatch-visibility": "node scripts/test-affiliate-dispatch-visibility.js",
    "test:affiliate-allocation-lifecycle": "node scripts/test-affiliate-allocation-lifecycle.js",
    "test:document-override-approval": "node scripts/test-document-override-approval.js",
    "db:cleanup-mocks": "node scripts/cleanup-mock-data.js",
    "db:reset-demo": "node scripts/reset-and-seed-demo-data.js",
    "db:rotate-default-passwords": "node scripts/rotate-default-passwords.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@sentry/node": "^10.59.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.19.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
